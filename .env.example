# Sudoku 2026 — environment variables
#
# Copy to apps/web/.env.local and apps/mobile/.env (per app) and fill in.
# Without these, the leaderboard API serves seeded MOCK data and auth is disabled.

# ── Web (Next.js) ──────────────────────────────────────────────────────────────
# Public Supabase project URL and anon key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key for writing leaderboard_entries / granting achievements.
# NEVER expose this to the client. Used only in server routes / edge functions.
SUPABASE_SERVICE_ROLE_KEY=

# ── Mobile (Expo) ──────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
